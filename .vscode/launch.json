{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Server (TypeScript)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "debug"],
      "cwd": "${workspaceFolder}/servers",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true
    },
    {
      "name": "Debug Server (Compiled)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/servers/dist/index.js",
      "cwd": "${workspaceFolder}/servers",
      "outFiles": ["${workspaceFolder}/servers/dist/**/*.js"],
      "sourceMaps": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Attach to Server Process",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true
    }
  ]
}
